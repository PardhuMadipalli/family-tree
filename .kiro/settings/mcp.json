{
  "mcpServers": {
    "chrome-devtools": {
      "command": "npx",
      "args": [
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "autoApprove": [
        "navigate_page",
        "take_screenshot",
        "lighthouse_audit",
        "list_console_messages",
        "get_console_message",
        "evaluate_script",
        "take_snapshot",
        "emulate",
        "click",
        "list_pages"
      ]
    },
    "local-browsermcp": {
      "args": [
        "@browsermcp/mcp@0.1.3"
      ],
      "autoApprove": [
        "browser_screenshot",
        "browser_snapshot",
        "browser_navigate",
        "browser_click"
      ],
      "command": "npx",
      "disabled": false
    }
  }
}